generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Asset {
  id        String   @id @default(cuid())
  code      String
  issuer    String
  decimals  Int
  iconUrl   String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, issuer])
  @@index([code])
}
